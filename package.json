{
  "name": "hertz",
  "version": "0.0.1",
  "description": "A React renderer for driving hardware peripherals. Projects internal React state to the physical world.",
  "main": "dist/index.mjs",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "types": "dist/index.d.mts",
  "scripts": {
    "example:clearcore-blink": "tsx src/examples/clearcore-blink.tsx",
    "example:clearcore-blink-with-telemetry": "tsx src/examples/clearcore-blink-with-telemetry.tsx",
    "example:clearcore-complex": "tsx src/examples/clearcore-complex.tsx",
    "example:clearcore-motor-velocity": "tsx src/examples/clearcore-motor-velocity.tsx",
    "example:clearcore-motor-position": "tsx src/examples/clearcore-motor-position.tsx",
    "example:clearcore-error-boundary": "tsx src/examples/clearcore-error-boundary.tsx",
    "build": "tsdown",
    "prepare": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.13.1",
  "dependencies": {
    "llamajet-driver-ts": "github:llamajet/llamajet-driver-ts",
    "node-graceful-shutdown": "^1.1.5",
    "react-error-boundary": "^6.0.3",
    "serialport": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-reconciler": "^0.33.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@types/react": "^19.2.0",
    "@types/react-reconciler": "^0.32.1",
    "react": "^19.2.0",
    "react-reconciler": "^0.33.0",
    "ts-node": "^10.9.2",
    "tsdown": "0.21.0-beta.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "llamajet-driver-ts"
    ]
  }
}
